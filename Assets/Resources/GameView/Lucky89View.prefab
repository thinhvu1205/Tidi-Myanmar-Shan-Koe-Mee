--- !u!114 &8902463845163472212
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 8857347545994620760}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Shan 9/ Shan 8\n\n- 2 \u1000\u1012\u1039\u1011\u1032\u1014\u1032\u1094
    8 \u101E\u102D\u102F\u1094\u1019\u101F\u102F\u1010\u1039 9 points \u101B\u1010\u1032\u1037\u1021\u1001\u102B
    \u1019\u103A\u102D\u1033\u1038\u1000\u102D\u102F\u1031\u1001\u105A\u1015\u102B\u1010\u101A\u1039\n-
    \u1000\u1005\u102C\u1038\u101E\u1019\u102C\u1038 \u108F\u103D\u1005\u1039\u1026\u1038
    points \u1010\u1030\u1031\u1014\u1015\u102B\u1000 \u1000\u1012\u1039\u1021\u1006\u1004\u1037\u1039\u1021\u1014\u102D\u1019\u1037\u1039\u1021\u103B\u1019\u1004\u1037\u1039\u1031\u1015\u105A\u1019\u1030\u1010\u100A\u1039\u103B\u1015\u102E\u1038
    \u1006\u1036\u102F\u1038\u103B\u1016\u1010\u1039\u1015\u102B\u1010\u101A\u1039\n\nEg:
    8\u2662J\u2665 (x1) > 4\u26604\u2663 (x2)\n- \u1000\u1012\u1039\u1021\u1006\u1004\u1037\u1039\u1021\u1014\u102D\u1019\u1037\u1039\u1021\u103B\u1019\u1004\u1037\u1039\u1015\u102B\u1010\u1030\u1031\u1014\u1015\u102B\u1000
    \u1000\u1012\u1039\u1021\u1005\u1036\u102F\u1010\u1030\u100A\u102E\u1019\u1088\u1031\u1015\u105A\u1019\u1030\u1010\u100A\u1039\u107F\u1015\u102E\u1038
    \u1006\u1036\u102F\u1038\u103B\u1016\u1010\u1039\u1015\u102B\u1010\u101A\u1039
    \n\nEg: K\u26629\u2662 (x2) >\_ K\u26639\u2665 (x1)\n\n\u1019\u1004\u1039\u1038\u1080\u1000\u102E\u1038\u101E\u1036\u102F\u1038\u1015\u102B\u1038\u1000\u1012\u1039\u1010\u1030\n-
    \u1010\u1014\u1039\u1016\u102D\u102F\u1038\u1010\u1030 \u1000\u1012\u1039 3 \u1000\u1012\u1039
    \u101B\u1010\u1032\u1037\u1021\u1001\u102B\u1019\u103A\u102D\u1033\u1038\u1000\u102D\u102F\u1031\u1001\u105A\u1015\u102B\u1010\u101A\u1039\n\u1025\u1015\u1019\u102C:
    (QQQ) x5 > (999) x5\n\n\u101E\u102C\u1019\u1014\u1039\u1000\u1012\u1039\u1019\u103A\u102C\u1038\n\n-
    A = 1 ; K,Q,J,10 = 0 ; 9=9 ; ...; 2=2\n\n-\u1000\u1012\u1039\u1005\u102F\u1005\u102F\u1031\u1015\u102B\u1004\u1039\u1038\u1010\u1014\u1039\u1016\u102D\u102F\u1038\u1019\u103A\u102C\u1038\u1010\u1030\u100A\u102E\u1031\u1014\u1015\u102B\u1000
    \u1000\u1012\u1039\u1021\u1014\u100A\u1039\u1038\u1006\u1036\u102F\u1038\u101E\u1030\u1000
    \u1021\u108F\u102D\u102F\u1004\u1039\u101B\u1019\u103D\u102C\u103B\u1016\u1005\u1039\u1015\u102B\u1010\u101A\u1039\n\nEg:
    8\u26658\u2663 (x2) > K\u26623\u26603\u2663\n\n- \u1000\u1012\u1039\u1005\u102F\u1005\u102F\u1031\u1015\u102B\u1004\u1039\u1038\u1010\u1014\u1039\u1016\u102D\u102F\u1038\u101E\u102C\u1019\u1000
    \u1000\u1012\u1039\u1014\u1036\u1015\u102B\u1010\u1039\u1019\u103A\u102C\u1038\u1015\u102B\u1010\u1030\u1031\u1014\u1015\u102B\u1000
    \u1000\u1012\u1039\u1021\u1006\u1004\u1037\u1039\u1021\u1014\u102D\u1019\u1037\u1039\u1021\u103B\u1019\u1004\u1037\u1039\u1031\u1015\u105A\u1019\u1030\u1010\u100A\u1039\u103B\u1015\u102E\u1038
    \u1006\u1036\u102F\u1038\u103B\u1016\u1010\u1039\u1031\u1015\u1038\u1015\u102B\u1010\u101A\u1039
    \n\nEg:\_ K\u2662Q\u26625\u2662 (x3) > Q\u26633\u26622\u2665\n\n- \u1000\u1012\u1039\u1021\u103B\u1019\u1004\u1037\u1039\u1010\u1030\u107F\u1015\u102E\u1038\u1010\u1014\u1039\u1016\u102D\u102F\u1038\u1010\u1030\u1031\u1014\u1015\u102B\u1000\u101C\u100A\u1039\u1038
    \u1000\u1012\u1039\u1021\u1005\u1036\u102F\u1031\u1015\u105A\u1019\u1030\u1010\u100A\u1039\u107F\u1015\u102E\u1038\u1006\u1036\u102F\u1038\u103B\u1016\u1010\u1039\u1031\u1015\u1038\u1015\u102B\u1010\u101A\u1039\n 
    \nEg: Q\u26604\u26653\u2663 > Q\u26635\u26622\u2665\n\n \u2660 > \u2662 > \u2665
    > \u2663"
  m_isRightToLeft: 0
